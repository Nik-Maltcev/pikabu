# PostgreSQL connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/pikabu_analyzer

# Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Cache TTL in hours
CACHE_TTL_HOURS=24

# Pikabu parser settings
# РФ прокси для запросов к pikabu.ru (нужен при деплое за рубежом)
# Форматы: socks5://user:pass@host:port, http://user:pass@host:port
PIKABU_PROXY_URL=
PIKABU_RETRY_DELAY_429=60
PIKABU_RETRY_COUNT_5XX=3
PIKABU_RETRY_DELAY_5XX=10

# Gemini API settings
GEMINI_MAX_RETRIES=3
GEMINI_CONTEXT_WINDOW=1000000
